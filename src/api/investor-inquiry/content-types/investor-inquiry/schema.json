{
  "kind": "collectionType",
  "collectionName": "investor_inquiries",
  "info": {
    "singularName": "investor-inquiry",
    "pluralName": "investor-inquiries",
    "displayName": "Investor Inquiry"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "investorStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "contacted",
        "confirmed",
        "rejected"
      ]
    },
    "submittedAt": {
      "type": "datetime"
    },
    "amount": {
      "type": "decimal"
    },
    "razorpayOrderId": {
      "type": "string"
    },
    "razorpayPaymentId": {
      "type": "string"
    }
  }
}
